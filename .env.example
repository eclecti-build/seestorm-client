# SeeStorm Frontend Environment Variables
# Copy this file to .env.local and fill in values

# ─── API Endpoints ───────────────────────────────────────────────
# URL to the CDN-cached active events JSON published by seestorm-ingest
# In production: your Cloudflare R2/CDN URL
# In development: can point to local ingest service or use NWS directly
NEXT_PUBLIC_EVENTS_API_URL=

# ─── Map Configuration ───────────────────────────────────────────
# Stadia Maps API key (free tier: 200K tiles/day, no credit card)
# Get one at: https://client.stadiamaps.com/signup/
# Leave empty to use the default unauthenticated style (rate limited)
NEXT_PUBLIC_STADIA_API_KEY=

# Map tile style URL (default: Stadia Alidade Smooth Dark)
# For Protomaps on R2 in prod, set to your self-hosted style.json URL
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.stadiamaps.com/styles/alidade_smooth_dark.json

# ─── Radar ───────────────────────────────────────────────────────
# NEXRAD radar tile URL template (default: Iowa Mesonet, free, no key)
NEXT_PUBLIC_RADAR_TILE_URL=https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-900913/{z}/{x}/{y}.png

# ─── NWS Direct (MVP mode, before ingest service is deployed) ────
# When EVENTS_API_URL is empty, the frontend polls NWS directly
NEXT_PUBLIC_NWS_AREA=WI
NEXT_PUBLIC_NWS_USER_AGENT=(seestorm.org, contact@seestorm.org)

# ─── Feature Flags ───────────────────────────────────────────────
# Set to "true" to enable storm reports layer (requires ingest service)
NEXT_PUBLIC_ENABLE_STORM_REPORTS=false

# --- Clerk auth (scaffolded, not wired) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
