# SeeStorm Frontend Environment Variables
# Copy this file to .env.local and fill in values

# ─── API Endpoints ───────────────────────────────────────────────
# Active events JSON snapshot. In production this is served by the Worker
# at the same origin under /v1/active-events.json — no env var needed,
# use a relative fetch. Override only for pointing local dev at a deployed
# preview URL or at the NWS API directly in MVP mode (leave empty for same-origin).
NEXT_PUBLIC_EVENTS_API_URL=

# ─── Map Configuration ───────────────────────────────────────────
# Basemap style URL. Leave empty to use the default (CartoDB Dark Matter,
# free + no-key, works from any origin). Override options:
#   - Stadia Alidade Smooth Dark (requires API key + allowlisted origin):
#     https://tiles.stadiamaps.com/styles/alidade_smooth_dark.json?api_key=YOUR_KEY
#   - Self-hosted Protomaps on R2:
#     https://data.seestorm.org/styles/dark.json
#   - OpenFreeMap dark:
#     https://tiles.openfreemap.org/styles/dark
NEXT_PUBLIC_MAP_STYLE_URL=

# ─── Radar ───────────────────────────────────────────────────────
# NEXRAD radar tile URL template (default: Iowa Mesonet, free, no key)
NEXT_PUBLIC_RADAR_TILE_URL=https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/nexrad-n0q-900913/{z}/{x}/{y}.png

# ─── NWS Direct (MVP mode, before ingest service is deployed) ────
# When EVENTS_API_URL is empty, the frontend polls NWS directly
NEXT_PUBLIC_NWS_AREA=WI
NEXT_PUBLIC_NWS_USER_AGENT=(seestorm.org, contact@seestorm.org)

# ─── Feature Flags ───────────────────────────────────────────────
# Set to "true" to enable storm reports layer (requires ingest service)
NEXT_PUBLIC_ENABLE_STORM_REPORTS=false
