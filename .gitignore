# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is committed intentionally

# vercel
.vercel

# wrangler — local dev state (miniflare caches, tmp bundles) from `wrangler dev`
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local state
.claude/

# Codex review artifacts
.codex-review/

# One-shot data regeneration workspace (see scripts/build-county-data.ts,
# scripts/build-zip-data.ts). Census shapefiles / gazetteers live here
# when refreshing public/geo/counties/ and public/data/zip-us.json.
/tmp/

# Ephemeral file written by dev-up.sh when seeding local R2.
.r2-seed-tmp.json

# Generated data files — built from Census source data via the scripts
# above. Too large to commit (~25 MB counties, ~2.4 MB ZIP table).
# Regenerate with: npm run build:geo && npm run build:zip
/public/geo/counties/
/public/data/zip-us.json
.claude/sessions/

# Local validation fixtures. In production `/v1/*` is served by the Worker
# from R2 — `public/v1/` is never a committed asset path. Ignoring it makes
# the local detection-validation snapshot impossible to commit/deploy by
# accident while still letting `next dev` serve it from public/.
/public/v1/
