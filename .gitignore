# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is committed intentionally

# vercel
.vercel

# wrangler — local dev state (miniflare caches, tmp bundles) from `wrangler dev`
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local state
.claude/

# Codex review artifacts
.codex-review/

# One-shot data regeneration workspace (see scripts/build-zip-data.ts).
# The Census Gazetteer / county shapefiles live here when refreshing
# public/data/zip-greatlakes.json. Not needed at runtime or in CI.
/tmp/
.claude/sessions/
